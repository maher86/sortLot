# Next.js — copy to .env.local and fill in values

# Laravel API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Laravel app URL (for Sanctum CSRF cookie)
NEXT_PUBLIC_APP_URL=http://localhost

# WebSocket (Laravel Reverb)
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=8080
NEXT_PUBLIC_WS_SCHEME=ws

# App name (shown in browser title, emails)
NEXT_PUBLIC_APP_NAME=SortLot

# Sentry (production only)
NEXT_PUBLIC_SENTRY_DSN=
