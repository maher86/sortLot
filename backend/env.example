APP_NAME=SortLot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dubai
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ───────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sortlot
DB_USERNAME=sortlot
DB_PASSWORD=sortlot_secret

# ─── Test Database ──────────────────────────
DB_TEST_DATABASE=sortlot_test

# ─── Cache / Session / Queue ────────────────
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Redis ──────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ───────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@sortlot.local
MAIL_FROM_NAME="${APP_NAME}"

# ─── File Storage (MinIO local / S3 prod) ───
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=sortlot
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Sanctum ────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost

# ─── Laravel Reverb (WebSocket) ─────────────
REVERB_APP_ID=sortlot-app
REVERB_APP_KEY=sortlot-key
REVERB_APP_SECRET=sortlot-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Horizon ────────────────────────────────
HORIZON_DASHBOARD_ENABLED=true

# ─── Sentry (production) ────────────────────
SENTRY_LARAVEL_DSN=
